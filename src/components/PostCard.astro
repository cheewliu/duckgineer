---
import { getTagColor, getCoverGradient } from '../utils/tagColor';
import { readingTime } from '../utils/readingTime';

interface Props {
  title: string;
  slug: string;
  date: Date;
  description: string;
  tags: string[];
  cover?: string;
  body?: string;
  draft?: boolean;
}
const { title, slug, date, description, tags, cover, body, draft } = Astro.props;

const firstTag = tags[0] ?? 'meta';
const tagColor = getTagColor(firstTag);
const gradient = getCoverGradient(firstTag);
const mins = body ? readingTime(body) : null;
const dateStr = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const isDev = import.meta.env.DEV;
---
<article class="post-card reveal">
  <a href={`/posts/${slug}`} tabindex="-1" aria-hidden="true">
    {cover
      ? <img class="post-card__img" src={cover} alt={title} loading="lazy" decoding="async" width="390" height="220" />
      : <div class="post-card__no-img" style={`background:${gradient}`}>
          <span style="font-size:1.5rem;opacity:0.2">◆</span>
        </div>
    }
  </a>
  <div class="post-card__body">
    <div class="post-card__category" style={`color:${tagColor.dot}`}>
      <span class="post-card__category-dot" style={`background:${tagColor.dot}`}></span>
      {firstTag}
      {isDev && draft && <span class="draft-badge">DRAFT</span>}
    </div>
    <a href={`/posts/${slug}`} class="post-card__title-link">
      <h3 class="post-card__title">{title}</h3>
    </a>
    <p class="post-card__excerpt">{description}</p>
    <div class="post-card__foot">
      <span>{dateStr}{mins ? ` · ${mins}m read` : ''}</span>
      <span class="post-card__arrow">→</span>
    </div>
  </div>
</article>
