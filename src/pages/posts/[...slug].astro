---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => {
    return import.meta.env.DEV || !data.draft;
  });

  const sorted = allPosts.sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
  );

  return sorted.map((post, index) => {
    // Related posts: top 3 by shared tag count
    const related = sorted
      .filter(p => p.id !== post.id)
      .map(p => ({
        ...p,
        score: p.data.tags.filter(t => post.data.tags.includes(t)).length,
      }))
      .filter(p => p.score > 0)
      .sort((a, b) => b.score - a.score || b.data.date.getTime() - a.data.date.getTime())
      .slice(0, 3);

    // Series: find all posts in same series
    let series = undefined;
    if (post.data.series) {
      const seriesPosts = sorted
        .filter(p => p.data.series === post.data.series)
        .map(p => ({ id: p.id, title: p.data.title, order: p.data.seriesOrder ?? 0 }));
      series = {
        name: post.data.series,
        order: post.data.seriesOrder ?? 0,
        posts: seriesPosts,
      };
    }

    return {
      params: { slug: post.id },
      props: {
        post,
        prev: sorted[index + 1] ?? null,
        next: sorted[index - 1] ?? null,
        related,
        series,
      },
    };
  });
}

const { post, prev, next, related, series } = Astro.props;
const { Content, headings } = await render(post);
---
<PostLayout
  title={post.data.title}
  date={post.data.date}
  description={post.data.description}
  tags={post.data.tags}
  cover={post.data.cover}
  body={post.body}
  headings={headings}
  related={related}
  series={series}
>
  <Content />

  <nav class="post-nav" aria-label="Post navigation">
    <div class="post-nav__item post-nav__item--prev">
      {prev && (
        <>
          <span class="post-nav__label">← Older</span>
          <a href={`/posts/${prev.id}`} class="post-nav__title">{prev.data.title}</a>
        </>
      )}
    </div>
    <div class="post-nav__item post-nav__item--next">
      {next && (
        <>
          <span class="post-nav__label">Newer →</span>
          <a href={`/posts/${next.id}`} class="post-nav__title">{next.data.title}</a>
        </>
      )}
    </div>
  </nav>
</PostLayout>
