---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTagColor } from '../../utils/tagColor';

const isDev = import.meta.env.DEV;
const all = await getCollection('posts', ({ data }) => isDev || !data.draft);

const tagMap = new Map<string, number>();
for (const post of all) {
  for (const tag of post.data.tags) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
---
<BaseLayout title="Topics" description="Browse all topics on Duckgineer.">
  <div class="page-header">
    <h1>Topics</h1>
    <p class="page-header__sub">{tags.length} topics across {all.length} posts</p>
  </div>

  <div class="tags-mosaic reveal-stagger">
    {tags.map(([tag, count]) => {
      const color = getTagColor(tag);
      return (
        <a href={`/tags/${tag}`} class="tag-card reveal">
          <div class="tag-card__glow" style={`background: ${color.dot}`}></div>
          <span class="tag-card__dot" style={`background: ${color.dot}`}></span>
          <span class="tag-card__name">#{tag}</span>
          <span class="tag-card__count">{count} post{count !== 1 ? 's' : ''}</span>
        </a>
      );
    })}
  </div>
</BaseLayout>

<style>
.tags-mosaic {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.tag-card {
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  padding: 1.75rem;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 14px;
  transition: all 0.3s var(--ease);
}

.tag-card:hover {
  border-color: var(--border-hover);
  box-shadow: var(--shadow-glow);
  transform: translateY(-3px);
}

.tag-card__glow {
  position: absolute;
  top: -40px;
  right: -40px;
  width: 100px;
  height: 100px;
  border-radius: 50%;
  opacity: 0.08;
  filter: blur(30px);
  transition: opacity 0.3s;
  pointer-events: none;
}
.tag-card:hover .tag-card__glow {
  opacity: 0.2;
}

.tag-card__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}

.tag-card__name {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.02em;
}

.tag-card__count {
  font-size: 0.78rem;
  color: var(--text-3);
  font-weight: 500;
}

@media (max-width: 768px) {
  .tags-mosaic { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .tags-mosaic { grid-template-columns: 1fr; }
  .tag-card { padding: 1.25rem; }
}
</style>
